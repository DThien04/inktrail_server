generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  displayName String   @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  bio         String?  @map("bio")
  role        Role     @default(reader)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  refreshTokens         RefreshToken[]
  passwordResetOtps     PasswordResetOtp[]
  stories               Story[]
  chapterLikes          ChapterLike[]
  chapterComments       ChapterComment[]
  chapterCommentLikes   ChapterCommentLike[]
  chapterCommentReports ChapterCommentReport[]
  moderatedComments     ChapterComment[]       @relation("CommentModeratedBy")
  moderatedChapters     Chapter[]              @relation("ChapterModeratedBy")
  moderatedStories      Story[]                @relation("StoryModeratedBy")
  storyReports          StoryReport[]
  chapterReports        ChapterReport[]
  readingProgresses     ReadingProgress[]
  readSessions          StoryReadSession[]
  storyRatings          StoryRating[]
  followingAuthors      AuthorFollow[]         @relation("AuthorFollowing")
  authorFollowers       AuthorFollow[]         @relation("AuthorFollowers")
  notificationsReceived Notification[]         @relation("UserNotifications")
  notificationsSent     Notification[]         @relation("NotificationActor")

  @@map("users")
}

model AuthorFollow {
  id         String   @id @default(uuid())
  followerId String   @map("follower_id")
  authorId   String   @map("author_id")
  createdAt  DateTime @default(now()) @map("created_at")

  follower User @relation("AuthorFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  author   User @relation("AuthorFollowers", fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([followerId, authorId])
  @@index([authorId, createdAt])
  @@index([followerId, createdAt])
  @@map("author_follows")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model PasswordResetOtp {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  email        String
  otpHash      String    @map("otp_hash")
  expiresAt    DateTime  @map("expires_at")
  attemptCount Int       @default(0) @map("attempt_count")
  usedAt       DateTime? @map("used_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, createdAt])
  @@index([userId, createdAt])
  @@index([expiresAt])
  @@map("password_reset_otps")
}

model Story {
  id           String      @id @default(uuid())
  title        String
  slug         String      @unique
  description  String?
  coverUrl     String?     @map("cover_url")
  status       StoryStatus @default(draft)
  moderationStatus     ModerationStatus @default(pending) @map("moderation_status")
  moderationCheckedAt  DateTime?        @map("moderation_checked_at")
  moderationCategories Json?            @map("moderation_categories")
  moderationConfidence Float?           @map("moderation_confidence")
  moderationReason     String?          @map("moderation_reason")
  isHidden     Boolean     @default(false) @map("is_hidden")
  hiddenAt     DateTime?   @map("hidden_at")
  hiddenById   String?     @map("hidden_by_id")
  hiddenReason String?     @map("hidden_reason")
  authorId     String      @map("author_id")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  author            User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  hiddenBy          User?              @relation("StoryModeratedBy", fields: [hiddenById], references: [id], onDelete: SetNull)
  chapters          Chapter[]
  ratings           StoryRating[]
  homeBanner        HomeBanner?
  storyGenres       StoryGenre[]
  readingProgresses ReadingProgress[]
  readSessions      StoryReadSession[]
  stats             StoryStat?
  notifications     Notification[]
  reports           StoryReport[]

  @@index([authorId])
  @@index([status, createdAt])
  @@index([status, isHidden, createdAt])
  @@index([moderationStatus, updatedAt])
  @@index([isHidden, hiddenAt])
  @@map("stories")
}

model ReadingProgress {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  storyId          String   @map("story_id")
  lastChapterIndex Int      @default(0) @map("last_chapter_index")
  lastPosition     Int?     @map("last_position")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId])
  @@index([userId, updatedAt])
  @@index([storyId])
  @@map("reading_progress")
}

model StoryReadSession {
  id               String   @id @default(uuid())
  storyId          String   @map("story_id")
  userId           String?  @map("user_id")
  deviceId         String?  @map("device_id")
  chapterIndex     Int      @default(0) @map("chapter_index")
  timeSpentSeconds Int      @default(0) @map("time_spent_seconds")
  maxScrollPercent Int      @default(0) @map("max_scroll_percent")
  countedAt        DateTime @default(now()) @map("counted_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([storyId, countedAt])
  @@index([userId, storyId, countedAt])
  @@index([deviceId, storyId, countedAt])
  @@map("story_read_sessions")
}

model StoryStat {
  storyId      String   @id @map("story_id")
  readCount    Int      @default(0) @map("read_count")
  likeCount    Int      @default(0) @map("like_count")
  commentCount Int      @default(0) @map("comment_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@map("story_stats")
}

model ChapterStat {
  chapterId    String   @id @map("chapter_id")
  likeCount    Int      @default(0) @map("like_count")
  commentCount Int      @default(0) @map("comment_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@map("chapter_stats")
}

model Chapter {
  id            String        @id @default(uuid())
  storyId       String        @map("story_id")
  chapterNumber Int           @map("chapter_number")
  title         String
  content       String
  status        ChapterStatus @default(draft)
  moderationStatus     ModerationStatus @default(pending) @map("moderation_status")
  moderationCheckedAt  DateTime?        @map("moderation_checked_at")
  moderationCategories Json?            @map("moderation_categories")
  moderationConfidence Float?           @map("moderation_confidence")
  moderationReason     String?          @map("moderation_reason")
  isHidden      Boolean       @default(false) @map("is_hidden")
  hiddenAt      DateTime?     @map("hidden_at")
  hiddenById    String?       @map("hidden_by_id")
  hiddenReason  String?       @map("hidden_reason")
  publishedAt   DateTime?     @map("published_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  story           Story                   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  hiddenBy        User?                   @relation("ChapterModeratedBy", fields: [hiddenById], references: [id], onDelete: SetNull)
  stats           ChapterStat?
  likes           ChapterLike[]
  comments        ChapterComment[]
  featuredComment ChapterFeaturedComment?
  notifications   Notification[]
  reports         ChapterReport[]

  @@unique([storyId, chapterNumber])
  @@index([storyId, status])
  @@index([storyId, moderationStatus, chapterNumber])
  @@index([storyId, isHidden, chapterNumber])
  @@index([isHidden, hiddenAt])
  @@map("chapters")
}

model StoryRating {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  storyId   String   @map("story_id")
  score     Int
  content   String
  editCount Int      @default(0) @map("edit_count")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId])
  @@index([storyId, createdAt])
  @@index([userId, createdAt])
  @@map("story_ratings")
}

model ChapterLike {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  chapterId String   @map("chapter_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@index([chapterId])
  @@index([userId])
  @@map("chapter_likes")
}

model ChapterComment {
  id                   String                         @id @default(uuid())
  userId               String                         @map("user_id")
  chapterId            String                         @map("chapter_id")
  content              String
  isEdited             Boolean                        @default(false) @map("is_edited")
  moderationStatus     ChapterCommentModerationStatus @default(pending) @map("moderation_status")
  moderationCheckedAt  DateTime?                      @map("moderation_checked_at")
  moderationCategories Json?                          @map("moderation_categories")
  moderationConfidence Float?                         @map("moderation_confidence")
  moderationReason     String?                        @map("moderation_reason")
  isHidden             Boolean                        @default(false) @map("is_hidden")
  hiddenAt             DateTime?                      @map("hidden_at")
  hiddenById           String?                        @map("hidden_by_id")
  hiddenReason         String?                        @map("hidden_reason")
  createdAt            DateTime                       @default(now()) @map("created_at")
  updatedAt            DateTime                       @updatedAt @map("updated_at")

  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter           Chapter                 @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  hiddenBy          User?                   @relation("CommentModeratedBy", fields: [hiddenById], references: [id], onDelete: SetNull)
  likes             ChapterCommentLike[]
  reports           ChapterCommentReport[]
  stats             ChapterCommentStat?
  featuredInChapter ChapterFeaturedComment?

  @@index([chapterId, createdAt])
  @@index([chapterId, isHidden, createdAt])
  @@index([chapterId, moderationStatus, createdAt])
  @@index([isHidden, hiddenAt])
  @@index([userId, createdAt])
  @@map("chapter_comments")
}

model ChapterCommentLike {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  commentId String   @map("comment_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment ChapterComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
  @@index([userId])
  @@map("chapter_comment_likes")
}

model ReportCase {
  id                     String                  @id @default(uuid())
  targetType             ReportTargetType        @map("target_type")
  targetId               String                  @map("target_id")
  status                 ReportCaseStatus        @default(pending)
  priority               ReportCasePriority      @default(low)
  resolutionAction       ReportResolutionAction? @map("resolution_action")
  lastResolutionAction   ReportResolutionAction? @map("last_resolution_action")
  riskScore              Int                     @default(0) @map("risk_score")
  aiFlagged              Boolean                 @default(false) @map("ai_flagged")
  aiCategories           Json?                   @map("ai_categories")
  aiConfidence           Float?                  @map("ai_confidence")
  aiSeverity             String?                 @map("ai_severity")
  aiSummary              String?                 @map("ai_summary")
  aiSuggestedAction      String?                 @map("ai_suggested_action")
  aiCheckedAt            DateTime?               @map("ai_checked_at")
  appealStatus           ReportAppealStatus?     @map("appeal_status")
  appealReason           String?                 @map("appeal_reason")
  appealSubmittedAt      DateTime?               @map("appeal_submitted_at")
  appealResolvedAt       DateTime?               @map("appeal_resolved_at")
  appealResolvedById     String?                 @map("appeal_resolved_by_id")
  appealAiSummary        String?                 @map("appeal_ai_summary")
  appealAiRecommendation String?                 @map("appeal_ai_recommendation")
  appealAiConfidence     Float?                  @map("appeal_ai_confidence")
  appealAiCheckedAt      DateTime?               @map("appeal_ai_checked_at")
  reportCount            Int                     @default(0) @map("report_count")
  uniqueReporterCount    Int                     @default(0) @map("unique_reporter_count")
  reopenedCount          Int                     @default(0) @map("reopened_count")
  lastReportedAt         DateTime                @default(now()) @map("last_reported_at")
  resolvedAt             DateTime?               @map("resolved_at")
  restoredAt             DateTime?               @map("restored_at")
  restoredById           String?                 @map("restored_by_id")
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")

  storyReports          StoryReport[]
  chapterReports        ChapterReport[]
  chapterCommentReports ChapterCommentReport[]

  @@unique([targetType, targetId])
  @@index([status, lastReportedAt])
  @@index([targetType, status, updatedAt])
  @@index([priority, status, lastReportedAt])
  @@map("report_cases")
}

model ChapterCommentReport {
  id          String                     @id @default(uuid())
  caseId      String                     @map("case_id")
  reporterId  String                     @map("reporter_id")
  commentId   String                     @map("comment_id")
  reason      ChapterCommentReportReason
  description String?
  status      ChapterCommentReportStatus @default(pending)
  createdAt   DateTime                   @default(now()) @map("created_at")
  updatedAt   DateTime                   @updatedAt @map("updated_at")
  resolvedAt  DateTime?                  @map("resolved_at")

  reportCase ReportCase     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  reporter   User           @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  comment    ChapterComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([reporterId, commentId])
  @@index([caseId, createdAt])
  @@index([commentId, createdAt])
  @@index([status, createdAt])
  @@index([reporterId, createdAt])
  @@map("chapter_comment_reports")
}

model StoryReport {
  id          String              @id @default(uuid())
  caseId      String              @map("case_id")
  reporterId  String              @map("reporter_id")
  storyId     String              @map("story_id")
  reason      ContentReportReason
  description String?
  status      ContentReportStatus @default(pending)
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  resolvedAt  DateTime?           @map("resolved_at")

  reportCase ReportCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  reporter   User       @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  story      Story      @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([reporterId, storyId])
  @@index([caseId, createdAt])
  @@index([storyId, createdAt])
  @@index([status, createdAt])
  @@index([reporterId, createdAt])
  @@map("story_reports")
}

model ChapterReport {
  id          String              @id @default(uuid())
  caseId      String              @map("case_id")
  reporterId  String              @map("reporter_id")
  chapterId   String              @map("chapter_id")
  reason      ContentReportReason
  description String?
  status      ContentReportStatus @default(pending)
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  resolvedAt  DateTime?           @map("resolved_at")

  reportCase ReportCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  reporter   User       @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  chapter    Chapter    @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([reporterId, chapterId])
  @@index([caseId, createdAt])
  @@index([chapterId, createdAt])
  @@index([status, createdAt])
  @@index([reporterId, createdAt])
  @@map("chapter_reports")
}

model ChapterCommentStat {
  commentId String   @id @map("comment_id")
  likeCount Int      @default(0) @map("like_count")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  comment ChapterComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@map("chapter_comment_stats")
}

model ChapterFeaturedComment {
  chapterId  String   @id @map("chapter_id")
  commentId  String   @unique @map("comment_id")
  score      Float    @default(0)
  reason     String?
  computedAt DateTime @default(now()) @map("computed_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  chapter Chapter        @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  comment ChapterComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([score])
  @@index([computedAt])
  @@map("chapter_featured_comments")
}

model Notification {
  id          String           @id @default(uuid())
  recipientId String           @map("recipient_id")
  actorId     String?          @map("actor_id")
  storyId     String?          @map("story_id")
  chapterId   String?          @map("chapter_id")
  type        NotificationType
  title       String
  body        String?
  linkUrl     String?          @map("link_url")
  meta        Json?
  isRead      Boolean          @default(false) @map("is_read")
  readAt      DateTime?        @map("read_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  recipient User     @relation("UserNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  actor     User?    @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  story     Story?   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  chapter   Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([recipientId, isRead, createdAt])
  @@index([recipientId, createdAt])
  @@index([actorId])
  @@index([storyId])
  @@index([chapterId])
  @@map("notifications")
}

model Announcement {
  id          String           @id @default(uuid())
  title       String
  body        String?
  linkUrl     String?          @map("link_url")
  type        AnnouncementType @default(system)
  isActive    Boolean          @default(true) @map("is_active")
  publishedAt DateTime         @default(now()) @map("published_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@index([isActive, publishedAt])
  @@map("announcements")
}

model Genre {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  storyGenres StoryGenre[]

  @@index([isActive, name])
  @@map("genres")
}

model StoryGenre {
  storyId   String   @map("story_id")
  genreId   String   @map("genre_id")
  createdAt DateTime @default(now()) @map("created_at")

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([storyId, genreId])
  @@index([genreId])
  @@map("story_genres")
}

model HomeBanner {
  id             String   @id @default(uuid())
  storyId        String   @unique @map("story_id")
  bannerImageUrl String?  @map("banner_image_url")
  sortOrder      Int      @default(0) @map("sort_order")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([isActive, sortOrder])
  @@map("home_banners")
}

enum Role {
  reader
  author
  admin
}

enum StoryStatus {
  draft
  published
}

enum ChapterStatus {
  draft
  published
}

enum ChapterCommentReportReason {
  spam
  abuse
  hate
  sexual
  violence
  other
}

enum ChapterCommentModerationStatus {
  pending
  approved
  rejected
}

enum ModerationStatus {
  pending
  approved
  rejected
  failed
}

enum ChapterCommentReportStatus {
  pending
  dismissed
  removed
}

enum ContentReportReason {
  spam
  copyright
  sexual
  violence
  hate
  misleading
  other
}

enum ContentReportStatus {
  pending
  dismissed
  action_taken
}

enum ReportTargetType {
  story
  chapter
  chapter_comment
}

enum ReportCaseStatus {
  pending
  resolved
}

enum ReportAppealStatus {
  pending
  accepted
  rejected
}

enum ReportCasePriority {
  low
  medium
  high
  critical
}

enum ReportResolutionAction {
  ignored
  story_hidden
  chapter_hidden
  comment_removed
}

enum NotificationType {
  system
  chapter_liked
  chapter_commented
  chapter_published
  story_published
  admin_message
}

enum AnnouncementType {
  system
  release
  event
  maintenance
}
